// db/prisma/schema.prisma
//
// This file is the single source of truth for your entire database.
// Every table, every column, every relationship is defined here.
// When you change this file, you run a migration and Prisma updates
// the database and regenerates the TypeScript client automatically.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
  output   = "../../db/generated/client"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// TENANT
//
// A tenant is one plumbing/HVAC business using TradeAgent.
// This is the top-level isolation boundary for everything.
// Every other table has a tenantId column pointing back here.
//
// Why is this the first model?
// Because without multi-tenancy baked in from day one, you will
// retrofit it later and it will be painful. Every query in the
// app will filter by tenantId — that's the rule, no exceptions.
//
// dispatcherPhone: the owner/manager's mobile number.
// This is where dispatch selection SMS alerts go — NOT the
// business line (phoneNumber). In Phase 1 this is one person.
// When we model StaffMember later, this column migrates there.
// ─────────────────────────────────────────────────────────────
model Tenant {
  id                String   @id @default(uuid())
  name              String
  // Their actual business phone — the one on their website
  phoneNumber       String   @unique
  // The owner/manager's mobile — receives dispatch SMS alerts
  dispatcherPhone   String?
  // The number WE provision via Twilio — calls to this get
  // intercepted by TradeAgent before ringing through
  twilioNumber      String?  @unique
  vapiPhoneNumberId String?  @unique
  // Set after the operator completes Stripe Connect onboarding.
  // Null until then — we can't send them money without it.
  stripeAccountId   String?
  plan              Plan     @default(ALPHA)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  contacts       Contact[]
  technicians    Technician[]
  priceBookItems PriceBookItem[]
  conversations  Conversation[]
  jobs           Job[]
  invoices       Invoice[]
  smsThreads     SmsThread[]

  @@map("tenants")
}

enum Plan {
  ALPHA
  STARTER
  GROWTH
  ENTERPRISE
}

// ─────────────────────────────────────────────────────────────
// CONTACT
//
// The homeowner or customer. Created automatically on their
// first inbound call — the AI captures their phone number
// from Twilio's caller ID and we upsert a record immediately.
//
// Why is phone the unique key and not email?
// Because trades customers call in. They often won't give an
// email. But we always have their phone number from the call.
// The @@unique([tenantId, phone]) constraint means the same
// homeowner can exist in two different tenant accounts without
// collision — Mike's Plumbing and Joe's HVAC are separate.
// ─────────────────────────────────────────────────────────────
model Contact {
  id        String   @id @default(uuid())
  tenantId  String
  name      String?
  phone     String
  address   String?
  city      String?
  state     String?
  zip       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  jobs          Job[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────
// CONVERSATION
//
// Every inbound interaction — voice call, SMS thread, web form.
// Deliberately decoupled from Job.
//
// The flow is: Conversation happens → AI triages it →
// if warranted, a Job is spawned from it.
// ─────────────────────────────────────────────────────────────
model Conversation {
  id            String             @id @default(uuid())
  tenantId      String
  contactId     String
  channel       Channel
  status        ConversationStatus @default(ACTIVE)
  transcriptUrl String?
  triageTier    TriageTier?
  aiSummary     String?
  startedAt     DateTime           @default(now())
  resolvedAt    DateTime?
  vapiCallId    String? 

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contact    Contact     @relation(fields: [contactId], references: [id])
  job        Job?
  smsThreads SmsThread[]

  @@index([tenantId])
  @@index([contactId])
  @@index([vapiCallId])
  @@map("conversations")
}

enum Channel {
  VOICE
  SMS
  WEB
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  TRANSFERRED
}

enum TriageTier {
  EMERGENCY
  URGENT
  ROUTINE
  ESTIMATE
}

// ─────────────────────────────────────────────────────────────
// SMS THREAD
//
// Tracks an active SMS exchange initiated by TradeAgent after
// a call ends. Each thread has a single purpose and expects
// exactly one meaningful reply before it closes.
//
// Why model this separately from Conversation?
// A voice Conversation spawns SMS threads as follow-up actions.
// They're different channels with different lifecycles. Mixing
// them would make the state machine unreadable.
//
// purpose drives the reply handler in /twilio/sms:
//   ADDRESS_CONFIRMATION → customer is replying with their address
//   DISPATCH_SELECTION   → owner is replying with a tech number (1, 2, etc.)
//
// to: the recipient's phone number (customer or dispatcher).
// This is how the inbound webhook knows which thread a reply
// belongs to — we match incoming `From` number against `to`.
//
// expiresAt: threads time out if no reply comes. A cron job
// (or Twilio's StatusCallback) marks them TIMED_OUT.
// For now we set expiry but don't enforce it — that's fine for Phase 1.
// ─────────────────────────────────────────────────────────────
model SmsThread {
  id             String          @id @default(uuid())
  tenantId       String
  conversationId String
  jobId          String
  // Who we're waiting to hear back from
  to             String
  purpose        SmsPurpose
  status         SmsThreadStatus @default(AWAITING_REPLY)
  createdAt      DateTime        @default(now())
  expiresAt      DateTime
  resolvedAt     DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id])
  job          Job          @relation(fields: [jobId], references: [id])
  messages     SmsMessage[]
  meta          Json?

  // Only one open thread per recipient per job.
  // Prevents duplicate threads if the webhook fires twice.
  @@unique([jobId, to, purpose])
  @@index([tenantId])
  @@index([to, status]) // the inbound webhook's primary lookup
  @@map("sms_threads")
}

enum SmsPurpose {
  ADDRESS_CONFIRMATION // sent to customer — waiting for address reply
  DISPATCH_SELECTION   // sent to dispatcher — waiting for tech choice reply
}

enum SmsThreadStatus {
  AWAITING_REPLY
  COMPLETED
  TIMED_OUT
}

// ─────────────────────────────────────────────────────────────
// SMS MESSAGE
//
// Individual messages within an SmsThread — both outbound
// (sent by us) and inbound (replies from customer/dispatcher).
//
// twilioSid: Twilio's message SID. Useful for delivery status
// lookups and debugging. Null on inbound messages since Twilio
// assigns SIDs to messages we send, not messages we receive
// (inbound messages have their own SID from Twilio's webhook).
// ─────────────────────────────────────────────────────────────
model SmsMessage {
  id        String       @id @default(uuid())
  threadId  String
  direction SmsDirection
  body      String
  // Twilio message SID — populated for outbound, also available
  // on inbound via the webhook payload (stored for traceability)
  twilioSid String?
  sentAt    DateTime     @default(now())

  thread SmsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("sms_messages")
}

enum SmsDirection {
  OUTBOUND // we sent it
  INBOUND  // customer or dispatcher replied
}

// ─────────────────────────────────────────────────────────────
// JOB
//
// Phase 1: conversationId, contactId, technicianId, status
// Phase 2 hooks: cvImageUrl, cvAnalysis
// Phase 3 hooks: lat, lng
// ─────────────────────────────────────────────────────────────
model Job {
  id             String    @id @default(uuid())
  tenantId       String
  contactId      String
  conversationId String?   @unique
  technicianId   String?
  status         JobStatus @default(PENDING)
  tradeType      TradeType
  description    String
  address        String
  city           String?
  state          String?
  zip            String?
  lat            Float?
  lng            Float?
  scheduledAt    DateTime?
  completedAt    DateTime?
  cvImageUrl     String?
  cvAnalysis     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  technician   Technician?   @relation(fields: [technicianId], references: [id])
  invoice      Invoice?
  smsThreads   SmsThread[]

  @@index([tenantId])
  @@index([technicianId])
  @@index([status])
  @@map("jobs")
}

enum JobStatus {
  PENDING
  DISPATCHED
  EN_ROUTE
  ON_SITE
  INVOICED
  COMPLETED
  CANCELLED
}

enum TradeType {
  PLUMBING
  HVAC
  ELECTRICAL
  GENERAL
}

// ─────────────────────────────────────────────────────────────
// TECHNICIAN
//
// Phase 3 hooks: currentLat, currentLng, telematicsDeviceId
// ─────────────────────────────────────────────────────────────
model Technician {
  id                 String           @id @default(uuid())
  tenantId           String
  name               String
  phone              String
  skillTags          TradeType[]
  status             TechnicianStatus @default(AVAILABLE)
  currentLat         Float?
  currentLng         Float?
  telematicsDeviceId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs   Job[]

  @@index([tenantId])
  @@index([status])
  @@map("technicians")
}

enum TechnicianStatus {
  AVAILABLE
  DISPATCHED
  ON_SITE
  OFF_DUTY
}

// ─────────────────────────────────────────────────────────────
// PRICE BOOK ITEM
// ─────────────────────────────────────────────────────────────
model PriceBookItem {
  id          String    @id @default(uuid())
  tenantId    String
  code        String?
  description String
  category    String?
  tradeType   TradeType
  laborCost   Float
  partsCost   Float     @default(0)
  flatRate    Float
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("price_book_items")
}

// ─────────────────────────────────────────────────────────────
// INVOICE
//
// lineItems shape at runtime:
//   [{ description, quantity, unitPrice, total, priceBookItemId? }]
// ─────────────────────────────────────────────────────────────
model Invoice {
  id                    String        @id @default(uuid())
  tenantId              String
  jobId                 String        @unique
  status                InvoiceStatus @default(DRAFT)
  audioTranscriptUrl    String?
  lineItems             Json
  subtotal              Float
  taxRate               Float         @default(0)
  total                 Float
  stripePaymentIntentId String?
  stripePaymentLink     String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}
