// db/prisma/schema.prisma
//
// This file is the single source of truth for your entire database.
// Every table, every column, every relationship is defined here.
// When you change this file, you run a migration and Prisma updates
// the database and regenerates the TypeScript client automatically.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
  output   = "../../db/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

// ─────────────────────────────────────────────────────────────
// TENANT
//
// A tenant is one plumbing/HVAC business using TradeAgent.
// This is the top-level isolation boundary for everything.
// Every other table has a tenantId column pointing back here.
//
// Why is this the first model?
// Because without multi-tenancy baked in from day one, you will
// retrofit it later and it will be painful. Every query in the
// app will filter by tenantId — that's the rule, no exceptions.
// ─────────────────────────────────────────────────────────────
model Tenant {
  id              String   @id @default(uuid())
  name            String
  // Their actual business phone — the one on their website
  phoneNumber     String   @unique
  // The number WE provision via Twilio — calls to this get
  // intercepted by TradeAgent before ringing through
  twilioNumber    String   @unique
  // Set after the operator completes Stripe Connect onboarding.
  // Null until then — we can't send them money without it.
  stripeAccountId String?
  plan            Plan     @default(ALPHA)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // These are Prisma relation fields — they don't create columns.
  // They just tell Prisma how to JOIN when you include them in a query.
  contacts       Contact[]
  technicians    Technician[]
  priceBookItems PriceBookItem[]
  conversations  Conversation[]
  jobs           Job[]
  invoices       Invoice[]

  @@map("tenants") // the actual PostgreSQL table name
}

enum Plan {
  ALPHA       // design partners — free or heavily discounted
  STARTER
  GROWTH
  ENTERPRISE
}

// ─────────────────────────────────────────────────────────────
// CONTACT
//
// The homeowner or customer. Created automatically on their
// first inbound call — the AI captures their phone number
// from Twilio's caller ID and we upsert a record immediately.
//
// Why is phone the unique key and not email?
// Because trades customers call in. They often won't give an
// email. But we always have their phone number from the call.
// The @@unique([tenantId, phone]) constraint means the same
// homeowner can exist in two different tenant accounts without
// collision — Mike's Plumbing and Joe's HVAC are separate.
// ─────────────────────────────────────────────────────────────
model Contact {
  id        String   @id @default(uuid())
  tenantId  String
  name      String?  // nullable — we might not get it on first call
  phone     String
  address   String?
  city      String?
  state     String?
  zip       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  jobs          Job[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────
// CONVERSATION
//
// Every inbound interaction — voice call, SMS thread, web form.
// Deliberately decoupled from Job.
//
// Why separate from Job?
// Not every conversation becomes a job. A caller might hang up,
// ask for a price quote, or call the wrong number. If we merged
// Conversation into Job we'd have jobs with no real work — that
// pollutes your dispatch board and your revenue reporting.
//
// The flow is: Conversation happens → AI triages it →
// if warranted, a Job is spawned from it.
// ─────────────────────────────────────────────────────────────
model Conversation {
  id            String             @id @default(uuid())
  tenantId      String
  contactId     String
  channel       Channel
  status        ConversationStatus @default(ACTIVE)
  // S3/R2 URL of the full call recording or SMS thread log
  transcriptUrl String?
  // Set by the AI after the call ends — drives job creation logic
  triageTier    TriageTier?
  // 1-2 sentence summary generated by Claude — shown on the job card
  aiSummary     String?
  startedAt     DateTime           @default(now())
  resolvedAt    DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id])
  // One conversation can spawn at most one job
  // The ? makes this nullable — no job until the AI decides one is warranted
  job     Job?

  @@index([tenantId])
  @@index([contactId])
  @@map("conversations")
}

enum Channel {
  VOICE
  SMS
  WEB
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ABANDONED    // caller hung up before triage finished
  TRANSFERRED  // escalated to a human dispatcher
}

enum TriageTier {
  EMERGENCY  // water on the floor, gas smell — dispatch immediately
  URGENT     // same-day service needed
  ROUTINE    // next available slot is fine
  ESTIMATE   // customer wants a quote, no job created yet
}

// ─────────────────────────────────────────────────────────────
// JOB
//
// The core operational unit. Every dispatched truck,
// every service call, every billable event is a Job.
//
// Phase 1: conversationId, contactId, technicianId, status
// Phase 2 hooks: cvImageUrl, cvAnalysis — null until the
//   computer vision pipeline populates them
// Phase 3 hooks: lat, lng — null until geocoding runs,
//   used by fleet proximity routing
//
// Notice cvAnalysis is Json type. That's because the CV
// pipeline will return a flexible object:
//   { severity, material, fittingsRequired, confidence }
// We don't know exactly what shape Phase 2 returns yet,
// so Json gives us flexibility without a migration.
// ─────────────────────────────────────────────────────────────
model Job {
  id             String    @id @default(uuid())
  tenantId       String
  contactId      String
  // Nullable — manually created jobs have no conversation
  conversationId String?   @unique
  // Nullable — unassigned until dispatched
  technicianId   String?
  status         JobStatus @default(PENDING)
  tradeType      TradeType
  description    String
  address        String
  city           String?
  state          String?
  zip            String?
  // Phase 3: populated by geocoding service after job creation
  lat            Float?
  lng            Float?
  scheduledAt    DateTime?
  completedAt    DateTime?
  // Phase 2 hooks — null in Phase 1, no migration needed later
  cvImageUrl     String?
  cvAnalysis     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  technician   Technician?   @relation(fields: [technicianId], references: [id])
  invoice      Invoice?

  @@index([tenantId])
  @@index([technicianId])
  @@index([status])
  @@map("jobs")
}

enum JobStatus {
  PENDING     // created, no technician assigned yet
  DISPATCHED  // technician assigned, not yet on the way
  EN_ROUTE    // Phase 3: telematics confirmed movement toward job
  ON_SITE     // technician checked in at the address
  INVOICED    // work done, invoice sent, awaiting payment
  COMPLETED   // paid and closed
  CANCELLED
}

enum TradeType {
  PLUMBING
  HVAC
  ELECTRICAL
  GENERAL
}

// ─────────────────────────────────────────────────────────────
// TECHNICIAN
//
// Field staff. The people in the trucks.
//
// skillTags is a PostgreSQL array of TradeType enums.
// This is why we need Postgres — SQLite has no array type.
// It lets you query: "find me all available plumbers"
// without a join table.
//
// Phase 3 hooks: currentLat, currentLng, telematicsDeviceId
// A background worker will poll the Samsara API and write
// to these columns. The dispatch logic then queries them
// to find the geographically closest available technician.
// ─────────────────────────────────────────────────────────────
model Technician {
  id                 String           @id @default(uuid())
  tenantId           String
  name               String
  phone              String
  skillTags          TradeType[]
  status             TechnicianStatus @default(AVAILABLE)
  // Phase 3 hooks
  currentLat         Float?
  currentLng         Float?
  telematicsDeviceId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs   Job[]

  @@index([tenantId])
  @@index([status])
  @@map("technicians")
}

enum TechnicianStatus {
  AVAILABLE
  DISPATCHED
  ON_SITE
  OFF_DUTY
}

// ─────────────────────────────────────────────────────────────
// PRICE BOOK ITEM
//
// The operator's flat-rate price book. These rows are created
// by the Python price book parser in packages/ai/ when the
// operator uploads their existing PDF or Excel price book.
//
// flatRate is what the customer pays — the number on the invoice.
// laborCost and partsCost are the operator's internal margin data.
// We store both so the operator can see job profitability later.
// ─────────────────────────────────────────────────────────────
model PriceBookItem {
  id          String    @id @default(uuid())
  tenantId    String
  code        String?   // operator's internal SKU if they have one
  description String
  category    String?   // e.g. "Water Heater", "Drain Cleaning"
  tradeType   TradeType
  laborCost   Float
  partsCost   Float     @default(0)
  flatRate    Float
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("price_book_items")
}

// ─────────────────────────────────────────────────────────────
// INVOICE
//
// Generated from the technician's voice dictation after the job.
//
// Why is lineItems Json and not a separate InvoiceLineItem table?
// Two reasons:
//
// 1. Invoices are immutable records once paid. If you normalize
//    line items into their own table with a FK to PriceBookItem,
//    a price change retroactively alters the invoice. A paid
//    invoice must always reflect what was charged at the time.
//    Json gives us a snapshot.
//
// 2. The number of line items per invoice is small (1-10) and
//    you never need to query individual line items in isolation.
//    You always load them with their invoice. No JOIN needed.
//
// The shape of lineItems at runtime:
//   [{ description, quantity, unitPrice, total, priceBookItemId? }]
// ─────────────────────────────────────────────────────────────
model Invoice {
  id                    String        @id @default(uuid())
  tenantId              String
  jobId                 String        @unique
  status                InvoiceStatus @default(DRAFT)
  // The Whisper input — stored so the operator can replay it
  audioTranscriptUrl    String?
  lineItems             Json
  subtotal              Float
  taxRate               Float         @default(0)
  total                 Float
  stripePaymentIntentId String?
  stripePaymentLink     String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT    // being assembled from voice dictation
  SENT     // Stripe link generated and texted to customer
  PAID     // Stripe webhook confirmed payment
  VOID     // cancelled before payment
}