{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "db/**/*",
    "apps/api/src/**/*",
    "apps/voice/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "db/generated"
  ]
}